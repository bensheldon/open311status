<% provide(:meta_title) { "Open311 Status - 311 API monitoring and analysis" } %>
<div class="well mb-3">
  <strong>
    Scanning <%= @cities.size %> Open311 endpoints every 10 minutes.
    For endpoint information visit the <a href="http://wiki.open311.org/GeoReport_v2/Servers" rel="noopener">Open311 Wiki</a>.
  </strong>
</div>

<div class="card card-default mb-3">
  <div class="card-header">
    <h3 class="card-title">Service Requests created during previous 48 hours</h3>
  </div>
  <div class="card-body">
    <% series_data = @cities.map { |city| { name: city.name, data: city.bucketed_service_requests } }.to_json %>
    <div data-controller="line-chart" data-line-chart-series-value="<%= series_data %>"></div>
  </div>
</div>

<div class="card card-default mb-3 card-table">
  <%= turbo_stream_from "cities" %>
  <table class="table table-sm table-bordered table-striped">
    <thead>
      <tr>
        <th>Endpoint</th>
        <th>Services</th>
        <th>Requests</th>
        <th>Request Types</th>
        <th data-sorter="false">
          Submitted requests
          <span class="badge badge-info">48 hours</span>
        </th>
        <th>Total</th>
        <th>Min/Hour</th>
        <th>Max/Hour</th>
        <th>Avg/Hour</th>
      </tr>
    </thead>
    <tbody>
      <%= render partial: 'city_row_content', layout: 'city_row', collection: @cities, as: :city %>
    </tbody>
  </table>
</div>

<h3>Recent Service Requests</h3>
<div class="card card-default card-table">
  <%= render 'service_requests', service_requests: @service_requests %>
</div>

<div class="text-center mt-3">
  <%= link_to "View all Service Requests", requests_path, class: 'btn btn-outline-dark' %>
</div>
